// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}




//!!! uuid のデフォルト設定がうまく行かないので生成関数を直接指定 本来は @default(uuid())

model category {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique

  red         Int     @default(0) @db.SmallInt
  green       Int     @default(0) @db.SmallInt
  blue        Int     @default(0) @db.SmallInt

  index       Int     @default(autoincrement()) @db.Integer @unique
  isPublished Boolean @default(false)
  

  content content[]
}



model content {
  id          String    @id @default(dbgenerated("gen_random_uuid()"))  @db.Uuid
  title       String
  body        String
  imgUrl      String?

  categoryId  String    @db.Uuid
  category    category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  index       Int       @default(autoincrement())
  isPublished Boolean   @default(false)


  @@unique([categoryId, index])
  contentprop contentprop[]
}



model contentprop {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String  @default("")
  imgUrl        String?
  youtubeEmbed  String?
  body          String

  contentId     String  @db.Uuid
  content       content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  index         Int     @default(autoincrement())


  @@unique([contentId, index])
}