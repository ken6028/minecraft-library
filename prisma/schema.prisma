generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model category {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique
  red         Int       @default(0) @db.SmallInt
  green       Int       @default(0) @db.SmallInt
  blue        Int       @default(0) @db.SmallInt
  
  index       Int       @unique @default(autoincrement())
  isPublished Boolean   @default(false)

  content     content[]
}

model content {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  body        String
  imgUrl      String?
  
  index       Int           @default(autoincrement())
  isPublished Boolean       @default(false)
  
  categoryId  String        @db.Uuid
  category    category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  contentprop contentprop[]
  linkedProps contentprop[] @relation("contentLink")

  @@unique([categoryId, index])
}

model contentprop {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  imgUrl        String?
  body          String
  title         String  @default("")
  youtubeEmbed  String?

  contentLinkId String? @db.Uuid
  contentLink   content? @relation("contentLink", fields: [contentLinkId], references: [id], onDelete: SetNull)

  index         Int     @default(autoincrement())
  
  contentId     String  @db.Uuid
  content       content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, index])
}
