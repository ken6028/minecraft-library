// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



model BookCategory {
  id          String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  name        String

  index       Int      @default(0)
  isPublic    Boolean  @default(false)

  books       Book[]
}


model Book {
  id          String   @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  title       String

  color       String   @db.Char(7) @default("#000000")

  index       Int      @default(0)
  isPublic    Boolean  @default(false)

  categoryId  String        @db.Uuid
  category    BookCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  content     BookContent[]
}



model BookContent {
  id          String    @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  
  title       String
  info        String?
  color       String    @db.Char(7) @default("#000000")


  index       Int       @default(0)
  isPublic    Boolean  @default(false)

  bookId      String    @db.Uuid
  book        Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)

  props        BookContentProp[]
  linkedProps   BookContentProp[] @relation("LinkedProps")
}




model BookContentProp {
  bookContentId String      @db.Uuid
  bookContent   BookContent @relation(fields: [bookContentId], references: [id], onDelete: Cascade)

  id          String    @id @db.Uuid @default(dbgenerated("gen_random_uuid()"))
  index       Int       @default(0)


  title       String
  imgUrl      String?
  info        String?
  body        String

  contentLinkId String? @db.Uuid
  contentLink   BookContent? @relation("LinkedProps", fields: [contentLinkId], references: [id], onDelete: SetNull)
}